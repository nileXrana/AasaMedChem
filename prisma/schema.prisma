generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  SELLER
}

enum DimensionType {
  WEIGHT
  VOLUME
  COUNT
}

enum OrderStatus {
  DRAFT
  CONFIRMED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(255)
  role      UserRole @default(SELLER)
  createdAt DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("users")
}

model Product {
  id                String        @id @default(uuid()) @db.Uuid
  name              String        @db.VarChar(255)
  dimensionType     DimensionType @map("dimension_type")
  pricePerBaseUnit  BigInt        @map("price_per_base_unit")
  stockBaseQuantity BigInt        @map("stock_base_quantity")
  createdAt         DateTime      @default(now()) @map("created_at")

  orderItems OrderItem[]

  @@index([name])
  @@map("products")
}

model Order {
  id         String      @id @default(uuid()) @db.Uuid
  sellerId   String      @map("seller_id") @db.Uuid
  status     OrderStatus @default(DRAFT)
  totalPrice BigInt      @map("total_price")
  createdAt  DateTime    @default(now()) @map("created_at")

  seller User        @relation(fields: [sellerId], references: [id])
  items  OrderItem[]

  @@map("orders")
}

model OrderItem {
  id                       String  @id @default(uuid()) @db.Uuid
  orderId                  String  @map("order_id") @db.Uuid
  productId                String  @map("product_id") @db.Uuid
  requestedDisplayQuantity Decimal @map("requested_display_quantity") @db.Decimal(16, 6)
  requestedDisplayUnit     String  @map("requested_display_unit") @db.VarChar(20)
  convertedBaseQuantity    BigInt  @map("converted_base_quantity")
  lineItemPrice            BigInt  @map("line_item_price")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}
